# ──────────────────────────────────────────────
# Twitch Beam — Environment Variables
# ──────────────────────────────────────────────
# Backup this file as .env.local and fill in your real credentials.
#
# How to get these values:
#   1. Go to https://dev.twitch.tv/console
#   2. Click "Register Your Application"
#   3. Set OAuth Redirect URL to: http://localhost:3000/api/twitch/callback
#   4. Copy the Client ID and generate a Client Secret
# ──────────────────────────────────────────────

# Required for real Twitch data
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_ACCESS_TOKEN=

# Optional: your Twitch username (broadcaster)
TWITCH_BROADCASTER_NAME=

# ──────────────────────────────────────────────
# If all TWITCH_* variables above are empty or
# missing, the dashboard automatically enters
#  MOCK MODE and generates fake live data.
# ──────────────────────────────────────────────
